<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Transforme seu negócio em uma revenda de sucesso</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#F5F5F0; --ink:#14181F; --blue:#1A3C6E; --amber:#E8A33D; --cta:#D94F30; --cta-d:#B93E22;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--ink);line-height:1.6;overflow-x:hidden}
h1,h2,h3{font-family:'Sora',sans-serif;font-weight:700;line-height:1.2}
.wrap{max-width:1120px;margin:0 auto;padding:0 24px}
.fade{opacity:0;transform:translateY(24px);transition:opacity .8s ease, transform .8s ease}
.fade.show{opacity:1;transform:translateY(0)}

header{position:sticky;top:0;z-index:50;background:rgba(245,245,240,.9);backdrop-filter:blur(8px);border-bottom:1px solid rgba(20,24,31,.08)}
.hd{display:flex;align-items:center;justify-content:space-between;padding:18px 24px}
.logo{font-family:'Sora',sans-serif;font-size:20px;font-weight:700;color:var(--blue)}
.hd-btn{border:1px solid var(--blue);color:var(--blue);background:none;padding:9px 18px;font-size:14px;cursor:pointer;transition:all .3s}
.hd-btn:hover{background:var(--blue);color:#fff}

.hero{position:relative;padding:100px 24px 140px;background:var(--blue);color:#fff;clip-path:polygon(0 0,100% 0,100% 88%,0 100%)}
.hero-grid{display:flex;align-items:center;gap:56px;max-width:1100px;margin:0 auto;flex-wrap:wrap}
.hero-text{flex:1;min-width:300px}
.hero h1{font-size:clamp(28px,4.2vw,46px);margin-bottom:20px}
.hero p{font-size:16px;max-width:480px;margin-bottom:32px;color:#C7D3E4}
.cta{display:inline-block;background:var(--cta);color:#fff;border:none;padding:15px 32px;font-size:15px;font-weight:600;cursor:pointer;transition:all .3s;border-radius:2px}
.cta:hover{background:var(--cta-d);transform:translateY(-2px)}
.hero-showcase{flex:1;min-width:280px;display:flex;justify-content:center}
.showcase-frame{width:320px;height:320px;border-radius:16px;overflow:hidden;perspective:900px}
.showcase-frame img{width:100%;height:100%;object-fit:cover;transition:transform .6s ease}
.showcase-frame:hover img{transform:rotateY(10deg) rotateX(4deg) scale(1.04)}

section{padding:90px 24px 70px}
.section-title{font-size:clamp(24px,3.6vw,36px);text-align:center;max-width:720px;margin:0 auto}
.section-sub{text-align:center;max-width:640px;margin:16px auto 50px;color:#4a5160;font-size:16px}

.adv-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px;max-width:1050px;margin:0 auto 60px}
.adv-card{background:#fff;border-radius:10px;padding:28px 22px;box-shadow:0 6px 18px rgba(20,24,31,.06);transition:transform .3s,box-shadow .3s}
.adv-card:hover{transform:translateY(-4px);box-shadow:0 12px 28px rgba(20,24,31,.1)}
.adv-icon{width:44px;height:44px;border-radius:10px;background:rgba(26,60,110,.1);color:var(--blue);display:flex;align-items:center;justify-content:center;margin-bottom:14px;font-size:18px;font-weight:700}
.adv-card p{font-size:14px;color:#4a5160}

.metrics{display:flex;justify-content:center;gap:60px;flex-wrap:wrap;max-width:900px;margin:0 auto}
.metric-n{font-family:'Sora',sans-serif;font-size:32px;font-weight:700;color:var(--blue)}
.metric-l{font-size:13px;color:#4a5160;margin-top:4px}

.carousel-wrap{max-width:1050px;margin:70px auto 0;position:relative}
.carousel{display:flex;gap:20px;overflow-x:auto;scroll-behavior:smooth;padding-bottom:10px}
.carousel::-webkit-scrollbar{height:6px}
.carousel::-webkit-scrollbar-thumb{background:rgba(20,24,31,.2);border-radius:6px}
.prod-card{flex:0 0 220px;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 6px 18px rgba(20,24,31,.06);position:relative;transition:transform .3s}
.prod-card:hover{transform:translateY(-4px)}
.prod-card img{width:100%;height:160px;object-fit:cover}
.prod-info{padding:16px}
.prod-info h4{font-size:14px;margin-bottom:4px}
.prod-price{position:absolute;inset:0;background:rgba(26,60,110,.92);color:#fff;display:flex;align-items:center;justify-content:center;flex-direction:column;opacity:0;transition:opacity .3s}
.prod-card:hover .prod-price{opacity:1}
.prod-price span{font-size:12px;color:#C7D3E4}
.prod-price strong{font-size:20px;margin-top:6px}
.carousel-arrows{display:flex;justify-content:center;gap:12px;margin-top:16px}
.carousel-arrows button{width:38px;height:38px;border-radius:50%;border:1px solid rgba(20,24,31,.15);background:#fff;cursor:pointer;font-size:16px}

.form-section{background:#fff;clip-path:polygon(0 6%,100% 0,100% 100%,0 100%)}
.form-card{max-width:600px;margin:0 auto;background:var(--bg);border-radius:10px;padding:44px;box-shadow:0 10px 40px rgba(20,24,31,.08)}
.form-card input,.form-card select{width:100%;padding:13px 16px;border:1px solid rgba(20,24,31,.15);border-radius:4px;font-family:inherit;font-size:15px;margin-bottom:16px;background:#fff}
.form-card label{font-size:13px;color:#5c6270;display:block;margin-bottom:6px}
.form-card button{width:100%}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.urgency-badge{max-width:600px;margin:24px auto 0;text-align:center;background:rgba(232,163,61,.15);color:#8a5c17;font-size:13px;padding:12px 18px;border-radius:6px;font-weight:500}

footer{background:var(--ink);color:#B9BEC7;padding:56px 24px 28px}
.foot-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:40px;max-width:1050px;margin:0 auto 36px}
.foot-col h4{color:#fff;font-size:14px;margin-bottom:14px;font-family:'Sora',sans-serif}
.foot-col p,.foot-col a{font-size:13px;color:#9198A5;display:block;text-decoration:none;margin-bottom:8px}
.foot-social{display:flex;gap:12px;margin-top:8px}
.foot-social a{width:34px;height:34px;border:1px solid #3a4150;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px}
.foot-bottom{text-align:center;font-size:12px;color:#6b7280;border-top:1px solid #2a2f38;padding-top:20px;max-width:1050px;margin:0 auto}
.verified{display:inline-flex;align-items:center;gap:6px;background:rgba(232,163,61,.15);color:var(--amber);font-size:12px;padding:6px 14px;border-radius:20px;margin-bottom:14px}

@media(max-width:900px){.adv-grid{grid-template-columns:repeat(2,1fr)}.foot-grid{grid-template-columns:1fr}.metrics{gap:32px}}

.mdl-ov{position:fixed;inset:0;background:rgba(20,24,31,.6);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;z-index:9999;padding:24px}
.mdl{background:#fff;border-radius:10px;padding:40px;max-width:420px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.3)}
.mdl h3{font-size:19px;margin-bottom:14px;color:var(--blue)}
.mdl p{font-size:14px;color:#4a5160;margin-bottom:24px}
.mdl a{display:inline-block;background:var(--cta);color:#fff;padding:13px 28px;border-radius:4px;text-decoration:none;font-size:14px;font-weight:600}
.mdl-close{margin-top:16px;background:none;border:none;color:#9198A5;font-size:13px;cursor:pointer;text-decoration:underline}
</style>
</head>
<body>

<header>
  <div class="hd wrap">
    <div class="logo">KitPro</div>
    <button class="hd-btn" onclick="document.getElementById('cadastro').scrollIntoView()">Seja revendedor</button>
  </div>
</header>

<section class="hero">
  <div class="hero-grid">
    <div class="hero-text">
      <h1 class="fade">Transforme seu negócio em uma revenda de sucesso.</h1>
      <p class="fade">Kits prontos, alta demanda de mercado e suporte completo para você revender com margem e sem complicação.</p>
      <button class="cta fade" onclick="document.getElementById('cadastro').scrollIntoView()">Quero me tornar revendedor</button>
    </div>
    <div class="hero-showcase fade">
      <div class="showcase-frame">
        <img src="https://picsum.photos/seed/kitprodutorevenda/500/500" alt="Kit de produtos para revenda">
      </div>
    </div>
  </div>
</section>

<section>
  <h2 class="section-title fade">Marca consolidada, produtos testados e aprovados</h2>
  <p class="section-sub fade">Ao se tornar parceiro, você tem acesso a kits com identidade própria, margem competitiva e suporte direto da nossa equipe comercial.</p>
  <div class="adv-grid">
    <div class="adv-card fade"><div class="adv-icon">%</div><p>Margem atrativa de revenda</p></div>
    <div class="adv-card fade"><div class="adv-icon">↑</div><p>Produtos com giro comprovado</p></div>
    <div class="adv-card fade"><div class="adv-icon">◎</div><p>Suporte comercial dedicado</p></div>
    <div class="adv-card fade"><div class="adv-icon">▣</div><p>Material de divulgação incluso</p></div>
  </div>
  <div class="metrics fade">
    <div><div class="metric-n" data-target="500" data-prefix="+">0</div><div class="metric-l">revendedores ativos</div></div>
    <div><div class="metric-n" data-target="98" data-suffix="%">0</div><div class="metric-l">de satisfação</div></div>
    <div><div class="metric-n" data-target="27" data-suffix=" estados">0</div><div class="metric-l">entrega em todo o Brasil</div></div>
  </div>

  <div class="carousel-wrap">
    <div class="carousel" id="carousel">
      <div class="prod-card fade"><img src="https://picsum.photos/seed/kititem1/300/200" alt="Kit item"><div class="prod-info"><h4>Kit Essencial</h4></div><div class="prod-price"><span>preço sugerido</span><strong>R$ 89,90</strong></div></div>
      <div class="prod-card fade"><img src="https://picsum.photos/seed/kititem2/300/200" alt="Kit item"><div class="prod-info"><h4>Kit Premium</h4></div><div class="prod-price"><span>preço sugerido</span><strong>R$ 149,90</strong></div></div>
      <div class="prod-card fade"><img src="https://picsum.photos/seed/kititem3/300/200" alt="Kit item"><div class="prod-info"><h4>Kit Duo</h4></div><div class="prod-price"><span>preço sugerido</span><strong>R$ 119,90</strong></div></div>
      <div class="prod-card fade"><img src="https://picsum.photos/seed/kititem4/300/200" alt="Kit item"><div class="prod-info"><h4>Kit Família</h4></div><div class="prod-price"><span>preço sugerido</span><strong>R$ 199,90</strong></div></div>
      <div class="prod-card fade"><img src="https://picsum.photos/seed/kititem5/300/200" alt="Kit item"><div class="prod-info"><h4>Kit Especial</h4></div><div class="prod-price"><span>preço sugerido</span><strong>R$ 169,90</strong></div></div>
    </div>
    <div class="carousel-arrows">
      <button onclick="document.getElementById('carousel').scrollBy({left:-240,behavior:'smooth'})">←</button>
      <button onclick="document.getElementById('carousel').scrollBy({left:240,behavior:'smooth'})">→</button>
    </div>
  </div>
</section>

<section class="form-section" id="cadastro">
  <h2 class="section-title fade">Quero ser um revendedor autorizado</h2>
  <p class="section-sub fade">Preencha os dados abaixo e nossa equipe entra em contato para liberar seu acesso.</p>
  <div class="form-card fade">
    <form id="leadForm">
      <div class="form-row">
        <div><label>CNPJ</label><input type="text" placeholder="00.000.000/0000-00"></div>
        <div><label>Nome</label><input type="text" placeholder="Seu nome" required></div>
      </div>
      <label>Segmento de atuação</label>
      <input type="text" placeholder="Ex: cosméticos, papelaria, moda">
      <div class="form-row">
        <div><label>WhatsApp</label><input type="tel" placeholder="(00) 00000-0000" required></div>
        <div><label>E-mail</label><input type="email" placeholder="seu@email.com"></div>
      </div>
      <button type="submit" class="cta">Quero ser um revendedor autorizado</button>
    </form>
  </div>
  <div class="urgency-badge fade">Vagas limitadas por região para garantir exclusividade territorial.</div>
</section>

<footer>
  <div class="foot-grid">
    <div class="foot-col">
      <div class="verified">✓ Empresa verificada</div>
      <h4>KitPro</h4>
      <p>Transformando negócios em revendas de sucesso em todo o Brasil.</p>
    </div>
    <div class="foot-col">
      <h4>Contato</h4>
      <a href="#">(11) 0000-0000</a>
      <a href="#">contato@kitpro.com.br</a>
      <p>São Paulo, SP</p>
    </div>
    <div class="foot-col">
      <h4>Institucional</h4>
      <a href="#">Sobre</a>
      <a href="#">Política de Privacidade</a>
      <a href="#">Termos de Uso</a>
      <div class="foot-social">
        <a href="#">in</a><a href="#">ig</a><a href="#">wa</a>
      </div>
    </div>
  </div>
  <div class="foot-bottom">© 2026 KitPro. Todos os direitos reservados.</div>
</footer>

<div class="mdl-ov" id="mdlOv">
  <div class="mdl">
    <h3>Este é um protótipo exclusivo</h3>
    <p>Este layout foi desenvolvido por Matheus como demonstração exclusiva. Para ativar as funcionalidades reais no seu domínio, clique abaixo para iniciarmos seu projeto.</p>
    <a href="https://wa.me/5500000000000" target="_blank" rel="noopener">Iniciar meu projeto</a>
    <br>
    <button class="mdl-close" onclick="document.getElementById('mdlOv').style.display='none'">Fechar</button>
  </div>
</div>

<script>
(function(){
  const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('show')}),{threshold:.15});
  document.querySelectorAll('.fade').forEach(el=>io.observe(el));

  const metrics=document.querySelectorAll('.metric-n');
  const mio=new IntersectionObserver(es=>{
    es.forEach(e=>{
      if(e.isIntersecting){
        const el=e.target, target=+el.dataset.target, suf=el.dataset.suffix||'', pre=el.dataset.prefix||'';
        let cur=0; const step=Math.max(1,Math.ceil(target/60));
        const iv=setInterval(()=>{cur+=step;if(cur>=target){cur=target;clearInterval(iv)}el.textContent=pre+cur.toLocaleString('pt-BR')+suf},20);
        mio.unobserve(el);
      }
    });
  },{threshold:.5});
  metrics.forEach(m=>mio.observe(m));

  function showModal(){document.getElementById('mdlOv').style.display='flex'}
  document.getElementById('leadForm').addEventListener('submit',e=>{e.preventDefault();showModal()});

  class WM extends HTMLElement{
    connectedCallback(){
      const r=this.attachShadow({mode:'open'});
      const s=document.createElement('style');
      s.textContent='.g{position:fixed;inset:-50%;z-index:99999;pointer-events:none;display:grid;grid-template-columns:repeat(6,1fr);transform:rotate(-28deg);opacity:.07}.g span{font-family:sans-serif;font-size:13px;color:#000;white-space:nowrap;padding:40px}';
      const g=document.createElement('div');g.className='g';
      for(let i=0;i<60;i++){const sp=document.createElement('span');sp.textContent='DEMONSTRAÇÃO EXCLUSIVA — MATHEUS';g.appendChild(sp)}
      r.appendChild(s);r.appendChild(g);
    }
  }
  customElements.define('wm-el',WM);
  document.body.appendChild(document.createElement('wm-el'));
})();
</script>
</body>
</html>
